{
  "name": "prompt-engineer",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "pnpm --filter @prompt-engineer/db generate",
    "db:push": "pnpm --filter @prompt-engineer/db db:push",
    "db:migrate": "pnpm --filter @prompt-engineer/db migrate",
    "db:seed": "pnpm --filter @prompt-engineer/db seed"
  },
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild"
    ]
  }
}